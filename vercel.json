{
  "version": 2,
  "builds": [
    {
      "src": "e_commerce/e_commerce/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "e_commerce/static/**",
      "use": "@vercel/static"
    },
    {
      "src": "e_commerce/media/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "e_commerce/static/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "e_commerce/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "e_commerce/e_commerce/wsgi.py"
    }
  ]
}
